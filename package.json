{
  "name": "web-playwright-saucedemo-pom",
  "version": "1.0.0",
  "description": "Automatizacion con Playwright TypeScript POM",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:auth": "playwright test tests/auth/",
    "test:checkout": "playwright test tests/checkout/",
    "test:debug": "playwright test --debug",
    "report:playwright": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "clean": "rimraf allure-results allure-report playwright-report test-results"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "allure-playwright": "^3.0.0",
    "rimraf": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.0"
  }
}
